################################################################################
# MEV BOT CONFIGURATION - POLYGON MAINNET
################################################################################

# ===================== RPC PROVIDERS =====================
# Alchemy API key (required for mempool listener and deployment)
ALCHEMY_API_KEY=HbG2B-oRSDCgwuEsEkISd

# WebSocket URL (for mempool listener - DO NOT CHANGE)
ALCHEMY_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/HbG2B-oRSDCgwuEsEkISd

# HTTP URLs (for backrun execution, deployment, and recovery)
ALCHEMY_HTTP_URL=https://polygon-mainnet.g.alchemy.com/v2/HbG2B-oRSDCgwuEsEkISd
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/HbG2B-oRSDCgwuEsEkISd
MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/HbG2B-oRSDCgwuEsEkISd

# ===================== DEPLOYMENT =====================
# Private key for contract deployment and transactions (do NOT share)
PRIVATE_KEY=366d5287e3b353091ef94589c8adebe3934b56513d9952c0b9eb25fcab69cdd1
# Required safety flag for mainnet deployment
# Set to "yes" to allow deployment to polygon mainnet (prevents accidental deploys)
CONFIRM_MAINNET=yes

# Deployed contract address (fill after deployment)
BACKRUN_CONTRACT=0x607de6c88F3a7DEF0a2F5A960F489DAdF22eF2b7

# ===================== BACKRUN STRATEGY =====================
# Enable/disable backrun execution
BACKRUN_ENABLED=1

# Profit threshold (in USDC equivalent, e.g., 0.5 = $0.50 min profit)
BACKRUN_IMPACT_THRESHOLD=0.5366d5287e3b35

# Price impact filter settings (DEX swap targets)
MIN_PRICE_IMPACT_PERCENT=0.3
MAX_PRICE_IMPACT_PERCENT=1.2
MIN_CALLDATA_BYTES=0
MIN_AMOUNTIN=0

# ===================== MONITORING & RECOVERY =====================
# Enable real-time monitoring and health checks
MONITORING_ENABLED=no

# Transaction cache timeout (ms)
SEEN_TX_TTL_MS=300000

# ===================== ALERTS (OPTIONAL) =====================
# Slack webhook for critical alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/...

# Discord webhook for monitoring reports
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ===================== TESTNET (OPTIONAL) =====================
# For Mumbai testnet validation
BACKRUN_CONTRACT_MUMBAI=0x...
TESTNET_PRIVATE_KEY=0x...